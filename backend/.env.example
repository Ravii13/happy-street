# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# Frontend/Production URL Configuration
# Use one of these for the frontend redirect URL after payment
# For Docker deployment on same domain, use PUBLIC_URL
# For external deployment, use PRODUCTION_URL or BASE_URL
PUBLIC_URL=https://yourdomain.com
# PRODUCTION_URL=https://yourdomain.com
# BASE_URL=https://yourdomain.com

# CORS Configuration (optional)
# Used for CORS origin if PUBLIC_URL/PRODUCTION_URL/BASE_URL is set
CORS_ORIGIN=https://yourdomain.com
